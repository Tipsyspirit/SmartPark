    "mongoose": "^8.0.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "firebase-admin": "^12.0.0",
    "razorpay": "^2.9.2",
    "axios": "^1.6.2",
    "express-validator": "^7.0.1",
    "nodemailer": "^6.9.7",
    "node-cron": "^3.0.3",
    "socket.io": "^4.6.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "qrcode": "^1.5.3",
