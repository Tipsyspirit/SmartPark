{
  "name": "smart-parking-pwa",
  "version": "1.0.0",
  "description": "Smart Parking Progressive Web App",
  "main": "index.html",
  "scripts": {
    "start": "python -m http.server 8000",
    "dev": "live-server --port=8000 --host=localhost",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss css/styles.css -o dist/styles.min.css",
    "build:js": "terser js/app.js -o dist/app.min.js",
    "test": "jest",
    "lint": "eslint js/**/*.js",
    "lint:fix": "eslint js/**/*.js --fix",
    "format": "prettier --write \"**/*.{html,css,js,json}\"",
    "deploy": "npm run build && netlify deploy --prod"
  },
  "keywords": [
    "pwa",
    "parking",
    "firebase",
    "razorpay",
    "google-maps"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "live-server": "^1.2.2",
    "postcss": "^8.4.32",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.1.1",
    "terser": "^5.26.0",
    "@testing-library/dom": "^9.3.3",
    "@testing-library/jest-dom": "^6.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
